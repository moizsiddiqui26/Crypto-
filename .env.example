# ==========================================
# Crypto AI SaaS - Environment Variables
# ==========================================

# [Database Configuration]
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=crypto_saas
DATABASE_URL=postgresql://admin:your_secure_password@db_host:5432/crypto_saas

# [Security & JWT Authentication]
SECRET_KEY=generate_a_very_long_secure_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# [AI / External API Keys]
# E.g., for CoinMarketCap, Binance, OpenAI etc.
EXTERNAL_CRYPTO_API_KEY=your_api_key_here
OPENAI_API_KEY=sk-your-openai-key

# [Environment]
ENVIRONMENT=production # production | development
LOG_LEVEL=INFO
